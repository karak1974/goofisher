{
    "name": "__MSG_appName__",
    "short_name": "__MSG_appName__",
    "description": "__MSG_appDescription__",
    "default_locale": "en",
    "version": "1.0.0",
    "manifest_version": 2,
    "icons": {
        "32": "icons/goofisher-32.png",
        "48": "icons/goofisher-48.png",
        "96": "icons/goofisher-96.png"
    },
    "browser_action": {
        "default_icon": {
            "32": "icons/goofisher-32.png"
        },
        "default_title": "__MSG_appName__"
    },
    "permissions": [
        "http://goofish.com/*",
        "https://goofish.com/*",
        "http://www.goofish.com/*",
        "https://www.goofish.com/*"
    ],
    "content_scripts": [{
        "matches": [
            "http://goofish.com/*",
            "https://goofish.com/*",
            "http://www.goofish.com/*",
            "https://www.goofish.com/*"
        ],
        "js": ["content.js"],
        "run_at": "document_idle"
    }]
}
